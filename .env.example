# =============================================================================
# LOCAL DEVELOPMENT ENVIRONMENT
# =============================================================================
# Copy this file to .env and fill in the values.
# For production deployment, use environment variables set in Cloud Run.
# =============================================================================

# Environment identifier: local, staging, production
ENVIRONMENT=local

# =============================================================================
# Database (Supabase PostgreSQL) — REQUIRED
# =============================================================================
# Get from: Supabase Dashboard → Project Settings → Database → Connection string
DATABASE_URL=postgresql+asyncpg://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres

# =============================================================================
# Supabase Auth — REQUIRED
# =============================================================================
# Get from: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_JWT_SECRET=your-jwt-secret
# Service role key (only needed for elevated operations like admin user management)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Frontend URL for CORS and email links
FRONTEND_URL=http://localhost:3000

# =============================================================================
# Google AI (Gemini) — REQUIRED
# =============================================================================
# Get from: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-gemini-api-key
# Get from: https://console.cloud.google.com/apis/credentials (Maps Geocoding API)
GOOGLE_MAPS_API_KEY=your-maps-api-key

# =============================================================================
# Twilio (WhatsApp) — REQUIRED for messaging
# =============================================================================
# Get from: https://console.twilio.com
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
# Messaging Service SID (production only, for WhatsApp Business API)
# TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxx
# WhatsApp template SIDs
# TWILIO_TEMPLATE_INTERVIEW_CONFIRMATION=HXxxxxxxxx
# TWILIO_TEMPLATE_INITIATE_PRE_SCREENING=HXxxxxxxxx
TWILIO_TEMPLATE_HEALTH_ALERT=HXxxxxxxxx
# Recipient for health alert WhatsApp messages
ALERT_WHATSAPP_NUMBER=whatsapp:+32xxxxxxxxx

# =============================================================================
# VAPI (Voice AI) — REQUIRED for voice screening
# =============================================================================
# Get from: https://dashboard.vapi.ai
VAPI_API_KEY=your-vapi-api-key
VAPI_PUBLIC_KEY=your-vapi-public-key
VAPI_SQUAD_ID=your-squad-id
VAPI_PHONE_NUMBER_ID=your-phone-number-id
VAPI_SERVER_URL=https://your-domain/vapi/events
# VAPI assistant IDs (configured in VAPI dashboard)
VAPI_FRONTLINE_ID=your-frontline-assistant-id
VAPI_INTERVIEWER_KNOCKOUT_ID=your-knockout-assistant-id
VAPI_INTERVIEWER_QUALIFY_ID=your-qualify-assistant-id
VAPI_END_CALL_ID=your-end-call-assistant-id
VAPI_SCHEDULER_ID=your-scheduler-assistant-id

# =============================================================================
# ElevenLabs (webhook only — voice agent has its own env files)
# =============================================================================
# Master voice agent ID from ElevenLabs dashboard
ELEVENLABS_AGENT_ID=your-agent-id
# Webhook secret from: ElevenLabs → Conversational AI → Agent → Webhook URL → Show secret
ELEVENLABS_WEBHOOK_SECRET=wsec_your-webhook-secret

# =============================================================================
# LiveKit (Voice Agent Infrastructure) — REQUIRED for voice
# =============================================================================
# Get from: https://cloud.livekit.io
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your-api-key
LIVEKIT_API_SECRET=your-api-secret
LIVEKIT_AGENT_NAME=pre-screening-dev
LIVEKIT_WEBHOOK_SECRET=
BACKEND_WEBHOOK_URL=http://localhost:8080
# SIP trunk for outbound phone calls
SIP_OUTBOUND_TRUNK_ID=your-trunk-id

# =============================================================================
# Meta WhatsApp Cloud API — Optional
# =============================================================================
# Get from: https://developers.facebook.com → WhatsApp → API Setup
META_ACCESS_TOKEN=your-meta-access-token
META_PHONE_NUMBER_ID=your-phone-number-id

# =============================================================================
# Microsoft Teams — Optional
# =============================================================================
# Get from: https://portal.azure.com → App Registrations
MS_TEAMS_APP_ID=your-app-id
MS_TEAMS_TENANT_ID=your-tenant-id
MS_TEAMS_CLIENT_SECRET=your-client-secret

# =============================================================================
# Prato Flex (Workforce Management) — Optional
# =============================================================================
PRATO_FLEX_API_TOKEN=your-api-token
PRATO_FLEX_API_URL=https://salesdemo.prato.be/webservice

# =============================================================================
# Yousign (E-Signatures) — Optional
# =============================================================================
# Get from: https://yousign.com → API → Sandbox key for dev, production key for prod
YOUSIGN_API_KEY=your-yousign-api-key
YOUSIGN_CUSTOM_EXPERIENCE_ID=your-experience-id
YOUSIGN_WEBHOOK_SECRET=your-webhook-secret

# =============================================================================
# Email (Resend) — Optional
# =============================================================================
# Get from: https://resend.com/api-keys
RESEND_API_KEY=your-resend-api-key
# EMAIL_FROM_ADDRESS=welkom@taloo.eu
# EMAIL_FROM_NAME=Taloo

# =============================================================================
# Observability — Optional but recommended
# =============================================================================
# Get from: https://sentry.io → Project Settings → Client Keys (DSN)
SENTRY_DSN=your-sentry-dsn

# =============================================================================
# Google Calendar & Drive (Service Account)
# =============================================================================
# Local dev: path to JSON key file
GOOGLE_SERVICE_ACCOUNT_FILE=credentials/your-service-account-key.json
# Cloud Run: set GOOGLE_SERVICE_ACCOUNT_INFO with the JSON key content instead
# Email to impersonate via domain-wide delegation (Google Workspace)
GOOGLE_CALENDAR_IMPERSONATE_EMAIL=hello@taloo.eu

# =============================================================================
# Local Development Only
# =============================================================================
# Ngrok reserved domain for webhook testing
# Create at: https://dashboard.ngrok.com/cloud-edge/domains
NGROK_DOMAIN=your-domain.ngrok.app

# =============================================================================
# Super Admin (optional, comma-separated email domains)
# =============================================================================
# SUPER_ADMIN_DOMAINS=taloo.eu
